# Copy to .env and fill in. Nothing here is a real secret:
# the chess.com Published-Data API is public/read-only — it has NO login,
# NO API key, and NEVER needs your chess.com password. Do not put it anywhere.

CHESSCOM_USERNAME=dungeon_crawler_carl
# Sent in the User-Agent header so chess.com can contact us instead of throttling
CONTACT_EMAIL=you@example.com

# Uncomment to override defaults (container sets these itself):
# DATABASE_URL=sqlite:///./data/chess.db
# ENABLE_SCHEDULERS=false
# PORT=8011
